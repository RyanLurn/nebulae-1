{
  "name": "nebulae-1",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:configs": "turbo run build --filter=./configs/*",
    "build:libs": "turbo run build --filter=./libs/* --filter=./docker-libs/* --filter=./node-libs/* --filter=./openapi-libs/*",
    "build:packages": "turbo run build --filter=./configs/* --filter=./libs/* --filter=./docker-libs/* --filter=./node-libs/* --filter=./openapi-libs/*",
    "fmt": "oxfmt --disable-nested-config",
    "fmt:check": "oxfmt --check --disable-nested-config",
    "lint": "pnpm run build:packages && oxlint --disable-nested-config",
    "lint:fix": "pnpm run build:packages && oxlint --fix --disable-nested-config",
    "check": "pnpm run lint && pnpm run fmt:check",
    "fix": "pnpm run lint:fix && pnpm run fmt",
    "map": "pnpm --filter \"@repo/map\" start"
  },
  "devDependencies": {
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.25.0",
    "turbo": "2.10.5"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.16.0",
      "onFail": "download"
    }
  }
}
