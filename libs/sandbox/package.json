{
  "name": "@repo/sandbox",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "try": "tsx --env-file=.env ./src/try.ts",
    "build": "tsdown --config-loader tsx",
    "test": "vitest --watch=false"
  },
  "dependencies": {
    "@repo/docker-client": "workspace:*",
    "@repo/error": "workspace:*",
    "@repo/json": "workspace:*",
    "@repo/node-env": "workspace:*",
    "@repo/node-path": "workspace:*",
    "@repo/result": "workspace:*",
    "dockerode": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/tsdown-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/dockerode": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
